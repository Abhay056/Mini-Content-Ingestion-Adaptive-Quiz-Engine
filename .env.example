# Database Configuration
# For SQLite (development - no external DB needed): sqlite:///./quiz_engine.db
# For PostgreSQL (production): postgresql://user:password@localhost:5432/quiz_engine
DATABASE_URL=sqlite:///./quiz_engine.db

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Application Settings
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# PDF Processing
MAX_PDF_SIZE_MB=50
PDF_UPLOAD_DIR=./pdfs

# Quiz Generation
MODEL_NAME=gemini-pro
TEMPERATURE=0.7
MAX_TOKENS=2048

# Adaptive Difficulty
INITIAL_DIFFICULTY=medium
MAX_DIFFICULTY_INCREASE_PER_CORRECT=1
MAX_DIFFICULTY_DECREASE_PER_INCORRECT=1
